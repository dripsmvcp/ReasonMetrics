/target
*.jsonl
!crates/*/tests/fixtures/*.jsonl
# Bundled bench task sets are compiled into the binary (include_str!), so they
# must be tracked despite the blanket *.jsonl ignore.
!crates/*/benchsets/*.jsonl
showcase/*.parquet
showcase/*.html
!showcase/*_report.html
pkg/

# local agent/session scratch — never publish
.superpowers/
.playwright-mcp/

# Python
__pycache__/
